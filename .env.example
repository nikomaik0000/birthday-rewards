# Supabase project settings (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Only used by server-side admin actions (bulk import, service-role tasks).
# Keep this secret — never expose it to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL, used for SEO/OpenGraph metadata
NEXT_PUBLIC_SITE_URL=http://localhost:3000
